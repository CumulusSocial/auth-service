APP_ENV=local
LOG_LEVEL=INFO
HTTP_PORT=8001

# Postgres
DATABASE_URL=postgresql+asyncpg://auth:auth@localhost:5432/auth_db

# JWT — paths to PEM files (RS256 keypair)
JWT_PRIVATE_KEY_PATH=./keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=./keys/jwt_public.pem
JWT_KID=auth-key-1
JWT_ISSUER=auth-service
JWT_TTL_SECONDS=900
